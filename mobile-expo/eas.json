{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://snack-distribuidora-app-production.up.railway.app/api"
      }
    },
    "preview_ios": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://snack-distribuidora-app-production.up.railway.app/api"
      }
    },
    "production": {
      "ios": {
        "autoIncrement": "buildNumber"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://snack-distribuidora-app-production.up.railway.app/api"
      }
    }
  }
}
